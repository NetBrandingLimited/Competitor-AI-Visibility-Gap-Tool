# SQLite database file (relative to project root)
DATABASE_URL="file:./prisma/dev.db"

# Windows + OneDrive: use `npm run dev:safe` — it junctions project `.next` to %LOCALAPPDATA%\CompetitorAI-next\next-cache.

# Dev-only: legacy x-dev-user-email header + old email cookie (optional)
ALLOW_DEV_AUTH_HEADERS="true"

# Weekly digest: optional notify address per org (Brand settings). Delivery requires one of:
# Resend (HTTPS, no extra deps beyond fetch):
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Acme <onboarding@resend.dev>"
# Or SMTP (nodemailer; URL form e.g. smtps://user:pass@smtp.example.com:465):
# SMTP_URL="smtps://..."
# SMTP_FROM="Acme <noreply@example.com>"
# (EMAIL_FROM is accepted as an alias for SMTP_FROM.)

# App-level encryption key for per-org stored secrets (required when saving connector JSON in UI)
# APP_SECRETS_KEY="replace-with-long-random-string"

# Reports freshness badge thresholds (hours)
# Fresh <= FRESH_HOURS, Aging <= AGING_HOURS, else Stale
# FRESH_HOURS="24"
# AGING_HOURS="72"

# Shared secret for automated cron hits (GET/POST /api/cron/weekly-scheduler). Use Authorization: Bearer <secret>.
# On Vercel, set CRON_SECRET in project env; crons invoke the route hourly (UTC).
# Default behavior is digest-only; add query full=1 for pipeline + trends + digest per org.
# CRON_SECRET="replace-with-long-random-string"

# --- Connector adapters (optional) ---
# Google Search Console (Search Analytics → visibility signals when configured)
# Enable "Google Search Console API" on the GCP project for the service account.
# Grant the service account access to the property in Search Console (Users and permissions).
# GSC_SITE_URL="https://www.example.com/"
# GOOGLE_APPLICATION_CREDENTIALS="C:/path/to/service-account.json"
# GSC_SERVICE_ACCOUNT_JSON="{...inline service account JSON...}"

# Google Analytics 4 (Data API → visibility signals when configured)
# Enable "Google Analytics Data API"; grant the service account access on the GA4 property.
# GA4_PROPERTY_ID="123456789"
# GA4_SERVICE_ACCOUNT_JSON="{...optional separate inline JSON; else GSC_* or GOOGLE_APPLICATION_CREDENTIALS}"
